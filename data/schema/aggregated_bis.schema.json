{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://metagor.logansworld.co.za/schemas/aggregated_bis.schema.json",
  "title": "Meta'gor aggregated BiS",
  "description": "Live-aggregated Mythic+ best-in-slot data, computed by scripts/aggregate.mjs from the top 50 Raider.IO players per specialization. Consumables, rotations, and content-creator links live in guides.json, not here.",
  "type": "object",
  "required": ["meta", "specializations"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["generated_at", "region", "sample_size", "source", "schema_version"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "expansion": { "type": ["string", "null"] },
        "expansion_id": { "type": ["integer", "null"] },
        "patch": { "type": ["string", "null"] },
        "season_id": { "type": "integer" },
        "period_id": { "type": ["integer", "null"], "description": "Current M+ period id used to source the leaderboards." },
        "region": { "type": "string", "enum": ["eu", "us", "kr", "tw", "eu+us", "eu+us+kr+tw"] },
        "regions": {
          "type": ["object", "null"],
          "description": "Per-region discovery info (season_id, period_id).",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "season_id": { "type": "integer" },
              "period_id": { "type": "integer" },
              "season_start": { "type": ["integer", "null"] },
              "season_end": { "type": ["integer", "null"] }
            }
          }
        },
        "sample_size": { "type": "integer", "minimum": 1, "maximum": 50 },
        "source": { "type": "string" },
        "failures": {
          "type": "object",
          "description": "How many profiles failed to fetch per spec, for transparency.",
          "additionalProperties": { "type": "integer" }
        },
        "schema_version": { "type": "integer", "const": 2 }
      },
      "additionalProperties": false
    },
    "specializations": {
      "type": "object",
      "description": "Keys are spec IDs in the form <class-slug>-<spec-slug>, e.g. demon-hunter-havoc.",
      "additionalProperties": { "$ref": "#/definitions/spec" }
    }
  },
  "definitions": {
    "spec": {
      "type": "object",
      "required": ["class", "spec", "sample_size", "stats", "gear"],
      "properties": {
        "class": { "type": "string" },
        "spec": { "type": "string" },
        "role": { "type": "string", "enum": ["dps", "tank", "healer", "support"] },
        "sample_size": { "type": "integer", "minimum": 1, "maximum": 50 },
        "stats": { "$ref": "#/definitions/stats" },
        "gear": { "$ref": "#/definitions/gear" },
        "gems": { "type": "array", "items": { "$ref": "#/definitions/aggregate-entry" } },
        "enchants": {
          "type": "object",
          "description": "Enchants per slot. Each slot maps to an array of enchant entries sorted by count descending.",
          "additionalProperties": { "type": "array", "items": { "$ref": "#/definitions/aggregate-entry" } }
        },
        "embellishments": { "type": "array", "items": { "$ref": "#/definitions/aggregate-entry" } },
        "talents": { "$ref": "#/definitions/talents" },
        "failures": {
          "type": "object",
          "description": "Per-spec failure counts for transparency.",
          "properties": {
            "profiles_skipped": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "stats": {
      "type": "object",
      "required": ["primary", "secondary_rating_averages", "secondary_percent_averages"],
      "properties": {
        "primary": {
          "type": "object",
          "description": "Mean of each primary stat across the sample.",
          "additionalProperties": { "type": "number" }
        },
        "secondary_weights": {
          "type": "object",
          "description": "Deprecated: normalized weight vector for the four secondaries, sum to 1.",
          "additionalProperties": { "type": "number" }
        },
        "secondary_gear_breakdown": {
          "type": "object",
          "description": "Deprecated alias for secondary_rating_averages.",
          "additionalProperties": { "type": "number" }
        },
        "secondary_rating_sums": {
          "type": "object",
          "description": "Total secondary stat rating sums across all 50 profiles.",
          "additionalProperties": { "type": "number" }
        },
        "secondary_averages": {
          "type": "object",
          "description": "Deprecated alias for secondary_rating_averages (kept for back-compat).",
          "additionalProperties": { "type": "number" }
        },
        "secondary_rating_averages": {
          "type": "object",
          "description": "Average raw rating per secondary stat across all profiles. Used to determine stat priority (matches murlok.io: sort by rating descending).",
          "additionalProperties": { "type": "number" }
        },
        "secondary_percent_averages": {
          "type": "object",
          "description": "Average in-game percentage per secondary stat across all profiles. The actual character-sheet value (e.g. 77% Mastery), matching Blizzard's /statistics 'value' field.",
          "additionalProperties": { "type": "number" }
        },
        "priority": {
          "type": "array",
          "description": "Stat priority order, highest rating average first (matches murlok.io).",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "gear": {
      "type": "object",
      "required": ["head", "neck", "shoulders", "back", "chest", "wrists", "hands", "waist", "legs", "feet", "finger1", "finger2", "trinket1", "trinket2", "mainhand", "offhand"],
      "properties": {
        "head":      { "$ref": "#/definitions/aggregate-entry" },
        "neck":      { "$ref": "#/definitions/aggregate-entry" },
        "shoulders": { "$ref": "#/definitions/aggregate-entry" },
        "back":      { "$ref": "#/definitions/aggregate-entry" },
        "chest":     { "$ref": "#/definitions/aggregate-entry" },
        "wrists":    { "$ref": "#/definitions/aggregate-entry" },
        "hands":     { "$ref": "#/definitions/aggregate-entry" },
        "waist":     { "$ref": "#/definitions/aggregate-entry" },
        "legs":      { "$ref": "#/definitions/aggregate-entry" },
        "feet":      { "$ref": "#/definitions/aggregate-entry" },
        "finger1":   { "$ref": "#/definitions/aggregate-entry" },
        "finger2":   { "$ref": "#/definitions/aggregate-entry" },
        "trinket1":  { "$ref": "#/definitions/aggregate-entry" },
        "trinket2":  { "$ref": "#/definitions/aggregate-entry" },
        "mainhand":  { "$ref": "#/definitions/aggregate-entry" },
        "offhand":   { "$ref": "#/definitions/aggregate-entry" }
      },
      "additionalProperties": false
    },
    "aggregate-entry": {
      "type": "object",
      "required": ["count", "percent"],
      "properties": {
        "item_id":  { "type": ["integer", "null"] },
        "spell_id": { "type": ["integer", "null"] },
        "name":     { "type": ["string", "null"] },
        "icon":     { "type": ["string", "integer", "null"], "description": "Wowhead icon texture (e.g. inv_helmet_74) or Blizzard media id." },
        "media_id": { "type": ["integer", "null"] },
        "ilvl":     { "type": ["integer", "null"] },
        "quality":  { "type": ["string", "null"] },
        "item_subclass": { "type": ["string", "null"] },
        "stats":    { "type": ["array", "null"], "items": { "type": "object" } },
        "set_name": { "type": ["string", "null"] },
        "set_effects": { "type": ["array", "null"], "items": { "type": "string" } },
        "enchantments": { "type": ["array", "null"], "items": { "type": "object" } },
        "socket_gem": { "type": ["object", "null"], "description": "Most popular gem socketed in this slot's item.", "properties": {
          "item_id": { "type": ["integer", "null"] },
          "name": { "type": ["string", "null"] },
          "icon": { "type": ["string", "integer", "null"] },
          "stat_display": { "type": ["string", "null"] },
          "count": { "type": "integer", "minimum": 0 }
        } },
        "source":  { "type": ["string", "null"], "description": "Item source label: Mythic+, Crafted, Raid (Mythic), Catalyst, etc." },
        "name_description": { "type": ["string", "null"] },
        "dungeon": { "type": ["string", "null"], "description": "Dungeon name for M+ items." },
        "encounter": { "type": ["string", "null"], "description": "Boss/encounter name for M+ items." },
        "raid": { "type": ["string", "null"], "description": "Raid name for raid items." },
        "boss": { "type": ["string", "null"], "description": "Boss name for raid items (or dungeon boss, reuses encounter)." },
        "alternatives": {
          "type": ["array", "null"],
          "description": "Top 5 alternative items for this slot, ranked by popularity.",
          "items": { "type": "object" }
        },
        "display":  { "type": ["string", "null"] },
        "stat_display": { "type": ["string", "null"], "description": "Stat bonuses text for gems (e.g. '+16 Mastery & +7 Critical Strike'). Also used for embellishment effect descriptions." },
        "item_name": { "type": ["string", "null"], "description": "For embellishments: the most common item carrying this effect." },
        "item_ids": { "type": ["array", "null"], "items": { "type": "integer" }, "description": "For embellishments: all item IDs that carry this effect." },
        "items": { "type": ["array", "null"], "items": { "type": "object" }, "description": "For embellishments: per-item breakdown with item_id and count." },
        "count":    { "type": "integer", "minimum": 0 },
        "percent":  { "type": "number",  "minimum": 0 }
      },
      "additionalProperties": false
    },
    "talents": {
      "type": "object",
      "required": ["loadout_string"],
      "properties": {
        "loadout_string": { "type": ["string", "null"] },
        "class_trees_used": { "type": "array", "items": { "type": "string" } },
        "spec_trees_used":  { "type": "array", "items": { "type": "string" } },
        "hero_talent": { "type": ["string", "null"] },
        "class_talents": { "type": "array", "items": { "type": "object" } },
        "spec_talents": { "type": "array", "items": { "type": "object" } },
        "hero_talents": { "type": "array", "items": { "type": "object" } },
        "tree": { "type": ["object", "null"], "description": "Talent tree structure with node positions and connections for visual rendering." }
      },
      "additionalProperties": false
    }
  }
}
